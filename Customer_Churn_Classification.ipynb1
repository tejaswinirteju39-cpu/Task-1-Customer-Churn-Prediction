    "# Display cross-validation results\n",
    "cv_results_df = pd.DataFrame(cv_results).T\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"CROSS-VALIDATION METRICS SUMMARY\")\n",
    "print(\"=\" * 60)\n",
