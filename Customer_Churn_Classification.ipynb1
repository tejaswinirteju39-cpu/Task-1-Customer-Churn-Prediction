   ],
   "source": [
    "# Visualize cross-validation results\n",
    "fig, axes = plt.subplots(2, 3, figsize=(15, 10))\n",
    "metrics = ['Accuracy', 'Precision', 'Recall', 'F1 Score', 'ROC-AUC']\n",
    "colors = ['#3498db', '#2ecc71', '#e74c3c']\n",
    "\n",
    "# Bar chart for all metrics\n",
    "x = np.arange(len(models))\n",
    "width = 0.15\n",
    "\n",
    "for idx, metric in enumerate(metrics):\n",
    "    row = idx // 3\n",
    "    col = idx % 3\n",
    "\n",
    "    values = [cv_results[model][metric] for model in cv_results.keys()]\n",
    "    bars = axes[row, col].bar(x, values, color=colors, alpha=0.8)\n",
    "    axes[row, col].set_xlabel('Model')\n",
    "    axes[row, col].set_ylabel(metric)\n",
    "    axes[row, col].set_title(f'{metric} Comparison', fontsize=11)\n",
    "    axes[row, col].set_xticks(x)\n",
    "    axes[row, col].set_xticklabels(list(cv_results.keys()), rotation=15, ha='right')\n",
    "    axes[row, col].set_ylim(0, 1)\n",
    "\n",
    "    # Add value labels on bars\n",
    "    for bar, val in zip(bars, values):\n",
    "        axes[row, col].text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.02,\n",
    "                            f'{val:.3f}', ha='center', fontsize=8)\n",
    "\n",
    "# Hide empty subplot\n",
    "axes[1, 2].axis('off')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "eNRpxLRVlXXy"
   },
   "source": [
    "# 5. Model Training and Evaluation on Test Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "dCq6jeGAgFfp"
   },
   "outputs": [],
   "source": [
    "# Train models on full training set and evaluate on test set\n",
    "test_results = {}\n",
    "trained_models = {}"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "yJk0h9fRyd5T"
   },
   "source": [
    "TEST SET EVALUATION"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "NzS1DxSexo4Y",
    "outputId": "887be6c6-85a0-4abb-d4c9-826a617a89f9"
   },
   "outputs": [],
   "source": [
    "for name, model in models.items():\n",
    "    print(f\"\\nTraining {name} on full training set...\")\n",
    "\n",
    "    # Create and train pipeline\n",
    "    pipeline = Pipeline([\n",
    "        ('preprocessor', preprocessor),\n",
    "        ('classifier', model)\n",
    "    ])\n",
    "\n",
    "    pipeline.fit(X_train, y_train)\n",
    "\n",
    "    # Predictions\n",
    "    y_pred = pipeline.predict(X_test)\n",
    "    y_prob = pipeline.predict_proba(X_test)[:, 1]\n",
    "\n",
    "    # Calculate metrics\n",
    "    test_results[name] = {\n",
    "        'Accuracy': accuracy_score(y_test, y_pred),\n",
    "        'Precision': precision_score(y_test, y_pred),\n",
    "        'Recall': recall_score(y_test, y_pred),\n",
    "        'F1 Score': f1_score(y_test, y_pred),\n",
    "        'ROC-AUC': roc_auc_score(y_test, y_prob)\n",
    "    }\n",
    "\n",
    "    # Store trained model\n",
    "    trained_models[name] = pipeline\n",
    "\n",
    "    print(f\"  ✓ {name} trained and evaluated\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "6I--ax3gysuU",
    "outputId": "92cbc1a4-180e-49e9-c9b3-a4e94340aaff"
   },
   "outputs": [],
   "source": [
    "# Display test results\n",
    "test_results_df = pd.DataFrame(test_results).T\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"TEST SET METRICS SUMMARY\")\n",
    "print(\"=\" * 60)\n",
    "print(test_results_df.round(4))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "IBE2hh1Uy-OV"
   },
   "source": [
    "COMPARISON: CROSS-VALIDATION vs TEST SET"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "VAoa7tbTy9HI",
    "outputId": "25ee7573-7eac-4acd-b807-335288f27790"
   },
   "outputs": [],
   "source": [
    "comparison_df = pd.DataFrame({\n",
    "    'Model': list(test_results.keys()),\n",
    "    'CV Accuracy': [cv_results[m]['Accuracy'] for m in test_results.keys()],\n",
    "    'Test Accuracy': [test_results[m]['Accuracy'] for m in test_results.keys()],\n",
    "    'CV ROC-AUC': [cv_results[m]['ROC-AUC'] for m in test_results.keys()],\n",
    "    'Test ROC-AUC': [test_results[m]['ROC-AUC'] for m in test_results.keys()]\n",
    "})\n",
    "print(comparison_df.round(4))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 374
    },
    "id": "8mTj3bFszKDn",
    "outputId": "47235df0-8111-4819-fa83-3877a7178d99"
   },
   "outputs": [],
   "source": [
    "# Confusion Matrix for all models\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 4))\n",
    "\n",
    "for idx, (name, pipeline) in enumerate(trained_models.items()):\n",
    "    y_pred = pipeline.predict(X_test)\n",
    "    cm = confusion_matrix(y_test, y_pred)\n",
    "\n",
    "    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[idx],\n",
    "                xticklabels=['No Churn', 'Churn'], yticklabels=['No Churn', 'Churn'])\n",
    "    axes[idx].set_xlabel('Predicted')\n",
    "    axes[idx].set_ylabel('Actual')\n",
    "    axes[idx].set_title(f'{name}\\nConfusion Matrix', fontsize=11)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 807
    },
    "id": "vlro22EpzSF_",
    "outputId": "06fe5d71-7791-4141-fe8b-afab360d7c99"
   },
   "outputs": [],
   "source": [
    "# ROC Curves for all models\n",
    "plt.figure(figsize=(10, 8))\n",
    "\n",
    "colors = ['#3498db', '#2ecc71', '#e74c3c']\n",
    "\n",
    "for idx, (name, pipeline) in enumerate(trained_models.items()):\n",
    "    y_prob = pipeline.predict_proba(X_test)[:, 1]\n",
    "    fpr, tpr, _ = roc_curve(y_test, y_prob)\n",
    "    auc_score = roc_auc_score(y_test, y_prob)\n",
    "\n",
    "    plt.plot(fpr, tpr, color=colors[idx], lw=2,\n",
    "             label=f'{name} (AUC = {auc_score:.4f})')\n",
    "\n",
    "plt.plot([0, 1], [0, 1], 'k--', lw=2, label='Random Classifier')\n",
    "plt.xlim([0.0, 1.0])\n",
    "plt.ylim([0.0, 1.05])\n",
    "plt.xlabel('False Positive Rate', fontsize=12)\n",
    "plt.ylabel('True Positive Rate', fontsize=12)\n",
    "plt.title('ROC Curves Comparison', fontsize=14)\n",
    "plt.legend(loc='lower right', fontsize=10)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "5V1Tr9Gklzkx"
   },
   "source": [
    "# 6. Best Model Selection and Feature Importance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "5TwoFWoz1Q55"
   },
   "outputs": [],
   "source": [
    "# Select best model based on ROC-AUC\n",
    "best_model_name = max(test_results.keys(), key=lambda x: test_results[x]['ROC-AUC'])\n",
    "best_pipeline = trained_models[best_model_name]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "plQ1TBSJ1i9t"
   },
   "source": [
    "BEST MODEL SELECTION"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "gmA_Zozv1neC",
    "outputId": "9d28b235-a121-4bcc-d5f8-0815bb734b63"
   },
   "outputs": [],
   "source": [
    "print(f\"\\n🏆 Best Model: {best_model_name}\")\n",
    "print(\"\\nPerformance Metrics:\")\n",
    "for metric, value in test_results[best_model_name].items():\n",
    "    print(f\"  {metric}: {value:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 1000
    },
    "id": "nvlbjGHe1nk8",
    "outputId": "35fe573c-0eba-4a38-a60f-6a8d9440d6d2"
   },
   "outputs": [],
   "source": [
    "# Feature Importance (for Random Forest and Gradient Boosting)\n",
    "if best_model_name in ['Random Forest', 'Gradient Boosting']:\n",
    "    # Get feature names after preprocessing\n",
    "    feature_names = (list(trained_models[best_model_name].named_steps['preprocessor']\n",
    "                          .named_transformers_['cat'].get_feature_names_out(cat_features)) +\n",
    "                     num_features)\n",
    "\n",
    "    # Get feature importances\n",
    "    importances = best_pipeline.named_steps['classifier'].feature_importances_\n",
    "\n",
    "    # Sort and display top 15 features\n",
    "    feature_importance_df = pd.DataFrame({\n",
    "        'Feature': feature_names,\n",
    "        'Importance': importances\n",
    "    }).sort_values('Importance', ascending=False).head(15)\n",
    "\n",
    "    plt.figure(figsize=(10, 8))\n",
    "    sns.barplot(data=feature_importance_df, x='Importance', y='Feature', palette='viridis')\n",
    "    plt.title(f'Top 15 Feature Importance - {best_model_name}', fontsize=12)\n",
    "    plt.xlabel('Importance')\n",
    "    plt.ylabel('Feature')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    print(\"\\nTop 15 Most Important Features:\")\n",
    "    print(feature_importance_df.to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "OQPETFJyl71r"
   },
   "source": [
    "# 7. Test Cases - Making Predictions with New Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "r0DCPBE0gVIg",
    "outputId": "c7220809-78f6-494f-ab70-3365dc158ea3"
   },
   "outputs": [],
   "source": [
    "# Create test cases for prediction\n",
    "test_cases = pd.DataFrame({\n",
    "    'gender': ['Male', 'Female', 'Male', 'Female'],\n",
    "    'SeniorCitizen': [0, 1, 0, 1],\n",
    "    'Partner': ['Yes', 'No', 'Yes', 'No'],\n",
    "    'Dependents': ['No', 'No', 'Yes', 'Yes'],\n",
    "    'tenure': [72, 6, 24, 48],\n",
    "    'PhoneService': ['Yes', 'Yes', 'No', 'Yes'],\n",
    "    'MultipleLines': ['No', 'Yes', 'No phone service', 'No'],\n",
    "    'InternetService': ['DSL', 'Fiber optic', 'No', 'DSL'],\n",
    "    'OnlineSecurity': ['Yes', 'No', 'No internet service', 'Yes'],\n",
    "    'OnlineBackup': ['Yes', 'No', 'No internet service', 'Yes'],\n",
    "    'DeviceProtection': ['Yes', 'No', 'No internet service', 'No'],\n",
    "    'TechSupport': ['Yes', 'No', 'No internet service', 'Yes'],\n",
    "    'StreamingTV': ['No', 'Yes', 'No internet service', 'No'],\n",
    "    'StreamingMovies': ['No', 'Yes', 'No internet service', 'No'],\n",
    "    'Contract': ['Two year', 'Month-to-month', 'One year', 'Two year'],\n",
    "    'PaperlessBilling': ['No', 'Yes', 'No', 'Yes'],\n",
    "    'PaymentMethod': ['Bank transfer', 'Electronic check', 'Credit card', 'Mailed check'],\n",
    "    'MonthlyCharges': [35.00, 89.99, 55.50, 75.00],\n",
    "    'TotalCharges': [2520.00, 540.00, 1332.00, 3600.00]\n",
    "})\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"TEST CASES FOR PREDICTION\")\n",
    "print(\"=\" * 60)\n",
    "print(\"\\nTest Case Data:\")\n",
    "print(test_cases.to_string())\n",
    "\n",
    "# Make predictions using the best model\n",
    "predictions = best_pipeline.predict(test_cases)\n",
    "probabilities = best_pipeline.predict_proba(test_cases)[:, 1]\n",
    "\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"PREDICTION RESULTS\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "results_df = pd.DataFrame({\n",
    "    'Customer': [f'Customer {i+1}' for i in range(len(test_cases))],\n",
    "    'Tenure (months)': test_cases['tenure'],\n",
    "    'Contract': test_cases['Contract'],\n",
    "    'Monthly Charges': test_cases['MonthlyCharges'],\n",
    "    'Churn Probability': [f'{p*100:.1f}%' for p in probabilities],\n",
    "    'Prediction': ['Churn' if p == 1 else 'No Churn' for p in predictions]\n",
    "})\n",
    "\n",
    "print(\"\\n\", results_df.to_string(index=False))\n",
    "\n",
    "# Display detailed prediction for each customer\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"DETAILED PREDICTIONS\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "for i, (pred, prob) in enumerate(zip(predictions, probabilities)):\n",
    "    print(f\"\\nCustomer {i+1}:\")\n",
    "    print(f\"  Contract: {test_cases['Contract'].iloc[i]}\")\n",
    "    print(f\"  Tenure: {test_cases['tenure'].iloc[i]} months\")\n",
    "    print(f\"  Monthly Charges: ${test_cases['MonthlyCharges'].iloc[i]:.2f}\")\n",
    "    print(f\"  Churn Probability: {prob*100:.1f}%\")\n",
    "    print(f\"  Prediction: {'⚠️ WILL CHURN' if pred == 1 else '✅ WILL NOT CHURN'}\")"
   ]
  },
